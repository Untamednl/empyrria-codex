---
import type { Sigil } from '../types/sigil';

interface Props {
	sigil: Sigil;
	compact?: boolean;
}

const { sigil, compact = false } = Astro.props;
const facets = sigil.facets ?? [];
---

{
	facets.length > 0 && (
		<ul
			class:list={[
				'flex flex-wrap gap-2',
				compact ? 'gap-1.5' : undefined,
			]}
			aria-label="Categories"
		>
			{facets.map((facet) => (
				<li>
					<span
						class:list={[
							'inline-block rounded border border-neutral-800/90 bg-neutral-900/50 font-medium text-neutral-500',
							compact ? 'px-2 py-0.5 text-[11px]' : 'px-2.5 py-1 text-xs',
						]}
					>
						{facet}
					</span>
				</li>
			))}
		</ul>
	)
}
