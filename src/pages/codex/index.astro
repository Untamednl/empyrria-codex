---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Codex · Empyrria Sigil Codex" currentPath={Astro.url.pathname}>
	<main class="mx-auto max-w-5xl px-6 py-12 md:px-8 md:py-16">
		<header>
			<p class="text-[0.65rem] font-medium uppercase tracking-[0.2em] text-neutral-500">Codex</p>
			<h1 class="mt-3 text-4xl font-semibold tracking-tight text-neutral-50 md:text-[2.5rem]">Codex</h1>
			<p class="mt-4 max-w-2xl text-sm leading-relaxed text-neutral-400">
				The Codex contains the core principles and structure behind sigils.
			</p>
		</header>

		<ul class="mt-12 max-w-xl space-y-4 md:mt-14 md:space-y-5">
			<li>
				<a
					href="/codex/what-is-a-sigil"
					class="text-sm text-neutral-400 underline-offset-4 transition-colors hover:text-amber-200/90 hover:underline focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-amber-500/35"
				>
					What is a Sigil
				</a>
			</li>
			<li>
				<a
					href="/codex/system-architecture"
					class="text-sm text-neutral-400 underline-offset-4 transition-colors hover:text-cyan-300/85 hover:underline focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-cyan-500/30"
				>
					System Architecture
				</a>
			</li>
		</ul>
	</main>
</Layout>
