---
import Layout from '../layouts/Layout.astro';
import codex from '../data/sigils.json';
import { isPubliclyDiscoverableSigil } from '../lib/sigils';
import { sigilTitleColorClass } from '../lib/sigilIdentity';
import { toSigilDisplayItem, type SigilRecord } from '../lib/sigilDisplay';

const sigils = codex.sigils.filter((sigil) => isPubliclyDiscoverableSigil(sigil));
const hero = sigils[0];
const heroDisplay = hero ? toSigilDisplayItem(hero as SigilRecord) : undefined;

function canonStatusLabel(status?: string): string | undefined {
	if (status === 'provisional') return 'Provisional Canon';
	return undefined;
}

/** Preview for grid cards: ellipsis only when truncated; prefer word boundary. */
function doctrinePreview(text: string, max = 100): string {
	const t = text.trim();
	if (t.length <= max) return t;
	let cut = t.slice(0, max).trimEnd();
	const lastSpace = cut.lastIndexOf(' ');
	if (lastSpace > Math.floor(max * 0.45)) cut = cut.slice(0, lastSpace);
	return `${cut.trimEnd()}…`;
}
---

<Layout title="Showcase · Empyrria Sigil Codex" currentPath={Astro.url.pathname}>
	<main class="mx-auto max-w-5xl px-6 py-12 md:px-8 md:py-16">
		<header class="mb-12 md:mb-14">
			<p class="text-[0.65rem] font-medium uppercase tracking-[0.2em] text-neutral-500">Showcase</p>
			<h1 class="mt-3 text-4xl font-semibold tracking-tight text-neutral-50 md:text-[2.5rem]">
				Empyrria Sigil Codex
			</h1>
			<p class="mt-4 max-w-2xl text-sm leading-relaxed text-neutral-400">
				A structured system of symbolic identities—states, functions, and relational patterns—in a curated chamber
				of the same archive as Browse.
			</p>
			<p class="mt-6">
				<a
					href="/codex/what-is-a-sigil"
					class="text-sm text-neutral-400 underline-offset-4 transition-colors hover:text-amber-200/90 hover:underline focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-amber-500/35"
				>
					What is a sigil
				</a>
			</p>
		</header>

		{
			hero && heroDisplay && (
				<section
					class="mb-14 rounded-2xl border border-amber-500/15 bg-neutral-900/35 p-8 shadow-sm shadow-black/25 md:mb-16 md:p-10"
					aria-labelledby="showcase-hero-heading"
				>
					<p class="text-[0.65rem] font-medium uppercase tracking-[0.18em] text-neutral-500">Featured</p>
					{
						heroDisplay.image && (
							<div
								class="mt-5 flex aspect-square w-[6rem] shrink-0 items-center justify-center rounded-lg border border-neutral-800/85 bg-neutral-950/45 p-2.5 md:w-[6.5rem]"
							>
								<img
									src={heroDisplay.image}
									alt={`${heroDisplay.title} sigil`}
									class="block max-h-full max-w-full object-contain"
									loading="eager"
									decoding="async"
								/>
							</div>
						)
					}
					{
						hero.category && (
							<span
								class:list={[
									'inline-block rounded border border-neutral-800/90 bg-neutral-950/40 px-2.5 py-1 text-[11px] font-medium uppercase tracking-wide text-neutral-500',
									heroDisplay.image ? 'mt-4' : 'mt-5',
								]}
							>
								{hero.category}
							</span>
						)
					}
					<h2
						id="showcase-hero-heading"
						class:list={[
							hero.category || heroDisplay.image ? 'mt-5' : 'mt-6',
							'text-3xl font-bold tracking-tight md:text-[2rem] md:leading-snug',
							sigilTitleColorClass(hero.slug),
						]}
					>
						{heroDisplay.title}
					</h2>
					<p class="text-doctrine mt-6 max-w-2xl text-[1.0625rem] leading-[1.85] text-amber-100/78">
						{heroDisplay.description}
					</p>
					<p class="mt-8">
						<a
							href={`/sigils/${hero.slug}`}
							class="text-sm text-neutral-400 underline-offset-4 transition-colors hover:text-amber-200/90 hover:underline focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-amber-500/35"
						>
							Open full entry
						</a>
					</p>
				</section>
			)
		}

		<ul class="grid list-none gap-8 sm:grid-cols-2 sm:gap-x-8 sm:gap-y-8">
			{
				sigils.map((sigil, i) => {
					const display = toSigilDisplayItem(sigil as SigilRecord);
					const statusLabel = canonStatusLabel(sigil.status);
					const provisional = (sigil as { status?: string }).status === 'provisional';
					const featuredCard = i === 0;
					return (
						<li>
							<a
								href={`/sigils/${sigil.slug}`}
								class:list={[
									'group block rounded-xl border p-6 shadow-sm shadow-black/30 outline-none transition-all duration-200 hover:-translate-y-px focus-visible:ring-2 focus-visible:ring-amber-500/35 focus-visible:ring-offset-2 focus-visible:ring-offset-neutral-950',
									featuredCard
										? 'border-amber-500/20 bg-neutral-900/40 hover:border-amber-400/28 hover:bg-neutral-900/55'
										: 'border-neutral-800/80 bg-neutral-900/35 hover:border-neutral-700/80 hover:bg-neutral-900/55',
								]}
							>
								{
									display.image && (
										<div class="mb-4 flex aspect-square w-[5.25rem] shrink-0 items-center justify-center rounded-lg border border-neutral-800/85 bg-neutral-950/45 p-2">
											<img
												src={display.image}
												alt={`${display.title} sigil`}
												class="block max-h-full max-w-full object-contain"
												loading="lazy"
												decoding="async"
											/>
										</div>
									)
								}
								<h3
									class:list={[
										'text-xl font-bold tracking-tight md:text-[1.35rem] md:leading-snug',
										sigilTitleColorClass(sigil.slug),
									]}
								>
									{display.title}
								</h3>
								{
									provisional && (
										<span class="mt-3 inline-flex rounded border border-amber-500/25 bg-amber-950/15 px-2 py-0.5 text-[0.68rem] font-bold uppercase tracking-[0.14em] text-amber-200/82">
											Provisional Canon
										</span>
									)
								}
								<div class="mt-3 text-[12px] leading-relaxed text-neutral-500">
									{sigil.category}
									{statusLabel && (
										<>
											{' '}
											· {statusLabel}
										</>
									)}
								</div>
								<p class="text-doctrine mt-4 text-[0.9375rem] leading-[1.8] text-amber-100/72 md:text-[1rem] md:leading-[1.82]">
									{doctrinePreview(display.description)}
								</p>
								{
									sigil.terms && sigil.terms.length > 0 && (
										<p class="mt-4 text-xs leading-relaxed text-neutral-500">{sigil.terms.join(', ')}</p>
									)
								}
							</a>
						</li>
					);
				})
			}
		</ul>
	</main>
</Layout>
