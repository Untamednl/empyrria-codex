---
import Layout from '../../layouts/Layout.astro';
import SigilMeta from '../../components/SigilMeta.astro';
import { sigilTitleColorClass } from '../../lib/sigilIdentity';
import { displayHeadline, type SigilRecord, toSigilDisplayItem } from '../../lib/sigilDisplay';
import { getPubliclyDiscoverableSigils, getSigilBySlug } from '../../lib/sigils';

export function getStaticPaths() {
	return getPubliclyDiscoverableSigils().map((s) => ({
		params: { slug: s.slug },
	}));
}

const { slug } = Astro.params;
const sigil = slug ? getSigilBySlug(slug) : undefined;

if (!sigil) {
	return new Response(null, { status: 404, statusText: 'Not Found' });
}

/** Phase A prototype: lore + relations preview split — document in EMPYRRIA_CODEX_MASTER. */
const FULL_ENTRY_UNDERLAY_SPLIT = '\n---\n';
const isFullLayoutPrototype = sigil.slug === 'top-iron-endurance';

const underlayText = typeof sigil.underlay === 'string' ? sigil.underlay.trim() : '';
const canonMeta = sigil as typeof sigil & { status?: string; visibility?: string };
const showProvisionalNotice = canonMeta.status === 'provisional';
const showMarkedPublicText = showProvisionalNotice && canonMeta.visibility === 'marked_public';

let loreFromUnderlay: string | undefined;
let relationsPreview: string | undefined;
const prototypeUnderlayConsumed =
	isFullLayoutPrototype && underlayText.includes(FULL_ENTRY_UNDERLAY_SPLIT);
if (prototypeUnderlayConsumed) {
	const idx = underlayText.indexOf(FULL_ENTRY_UNDERLAY_SPLIT);
	loreFromUnderlay = underlayText.slice(0, idx).trim();
	relationsPreview = underlayText.slice(idx + FULL_ENTRY_UNDERLAY_SPLIT.length).trim();
}
const showLegacyUnderlay = underlayText.length > 0 && !prototypeUnderlayConsumed;
const showPrototypeLoreSection = Boolean(loreFromUnderlay && loreFromUnderlay.length > 0);
const showRelationsPreview = Boolean(relationsPreview && relationsPreview.length > 0);

/** Split at first ":" only; wording unchanged. Lines without ":" stay whole. */
type UnderlayLine =
	| { kind: 'pair'; label: string; value: string }
	| { kind: 'plain'; text: string };

function parseUnderlayLine(line: string): UnderlayLine {
	const idx = line.indexOf(':');
	if (idx === -1) {
		return { kind: 'plain', text: line };
	}
	return {
		kind: 'pair',
		label: line.slice(0, idx + 1).trimEnd(),
		value: line.slice(idx + 1).replace(/^\s+/, ''),
	};
}

function nonEmptyTrimmed(value: string | undefined): string | undefined {
	if (typeof value !== 'string') return undefined;
	const t = value.trim();
	return t.length > 0 ? t : undefined;
}

const geometry = nonEmptyTrimmed(sigil.geometry);
const usage = nonEmptyTrimmed(sigil.usage);
const category = nonEmptyTrimmed(sigil.category);
const showFunctionStrip = Boolean(usage);

const classificationGeometry = geometry;
/** Classification shows geometry + category only on public detail (colour + terms hidden Phase 1). */
const showClassification = Boolean(classificationGeometry || category);

const loreContextText = nonEmptyTrimmed(sigil.loreContext);
const characterLinkText = nonEmptyTrimmed(sigil.characterLink);
const placeOfOriginText = nonEmptyTrimmed(sigil.placeOfOrigin);
const relationshipLines = (sigil.sigilRelationships ?? [])
	.map((s) => (typeof s === 'string' ? s.trim() : ''))
	.filter((s) => s.length > 0);
const showEditorialLoreContext = Boolean(loreContextText);
const showCharacterLink = Boolean(characterLinkText);
const showPlaceOfOrigin = Boolean(placeOfOriginText);
const showSigilRelationships = relationshipLines.length > 0;

const display = toSigilDisplayItem(sigil as SigilRecord);
const explicitMeaning = nonEmptyTrimmed(sigil.meaning);
const explicitLayer = nonEmptyTrimmed(sigil.layer);
const headline = displayHeadline(sigil as SigilRecord);
const registryName = sigil.name.trim();
const showRegistryNameSubtitle = registryName.length > 0 && headline !== registryName;
const showDoctrineLead = explicitMeaning !== undefined || explicitLayer !== undefined;
---

<Layout title={`${headline} · Empyrria Sigil Codex`} currentPath={Astro.url.pathname}>
	<main class="mx-auto max-w-2xl px-6 py-12 md:px-8 md:py-16">
		<p class="text-[0.65rem] font-medium uppercase tracking-[0.2em] text-neutral-500">Sigil</p>
		{
			sigil.image && (
				<div class="mt-5 flex aspect-square w-[7.5rem] items-center justify-center rounded-lg border border-neutral-800/75 bg-neutral-950/40 p-3 md:w-[8.5rem] md:p-3.5">
					<img
						src={sigil.image}
						alt={`${sigil.name} sigil`}
						class="block max-h-full max-w-full object-contain"
						loading="eager"
						decoding="async"
					/>
				</div>
			)
		}
		<h1
			class:list={[
				sigil.image ? 'mt-6' : 'mt-5',
				'text-[2.125rem] font-bold tracking-tight md:text-[2.75rem] md:leading-[1.08]',
				sigilTitleColorClass(sigil.slug),
			]}
		>
			{headline}
		</h1>
		{
			showRegistryNameSubtitle && (
				<p class="mt-3 max-w-prose text-sm leading-snug text-neutral-500/90 md:text-[0.9375rem]">
					{registryName}
				</p>
			)
		}

		<div class="mt-5">
			<SigilMeta sigil={sigil} compact variant="archival" />
		</div>

		{
			showDoctrineLead && (
				<div class="mt-10 space-y-3 md:mt-11">
					{
						explicitMeaning && (
							<p
								class="max-w-prose whitespace-pre-wrap break-words text-[0.9375rem] leading-relaxed text-neutral-400/85 md:text-[1rem]"
							>
								{display.meaning}
							</p>
						)
					}
					{
						explicitLayer && (
							<p
								class="whitespace-pre-wrap break-words text-[0.65rem] font-medium uppercase tracking-[0.16em] text-neutral-500/70"
							>
								{display.layer}
							</p>
						)
					}
				</div>
			)
		}

		{
			showProvisionalNotice && (
				<div class="mt-10 rounded-lg border border-amber-500/25 bg-amber-950/15 px-4 py-3 text-sm leading-relaxed text-amber-100/78 md:mt-11">
					<p class="text-[0.7rem] font-bold uppercase tracking-[0.16em] text-amber-200/88">
						Provisional Canon
					</p>
					{showMarkedPublicText && (
						<p class="mt-1.5 text-[0.875rem] text-amber-100/64">
							This entry is public but still under canon review.
						</p>
					)}
				</div>
			)
		}

		<section class="mt-[4.5rem] border-t border-neutral-800/45 pt-11 md:mt-[5.25rem] md:pt-[3.25rem]" aria-labelledby="doctrine-heading">
			<h2
				id="doctrine-heading"
				class="border-b border-neutral-800/30 pb-5 text-lg font-bold uppercase tracking-[0.14em] text-amber-200/88 md:text-xl"
			>
				Doctrine
			</h2>
			<p
				class="text-doctrine mt-7 whitespace-pre-wrap break-words text-[1.0625rem] leading-[1.88] text-amber-100/78 sm:text-[1.0625rem]"
			>
				{sigil.doctrine}
			</p>
		</section>

		{
			showEditorialLoreContext && loreContextText && (
				<section
					class="mt-[3.25rem] border-t border-neutral-800/32 pt-10 md:mt-[3.5rem] md:pt-11"
					aria-labelledby="lore-context-field-heading"
				>
					<h2
						id="lore-context-field-heading"
						class="border-b border-neutral-800/30 pb-4 text-[0.7rem] font-bold uppercase tracking-[0.14em] text-neutral-400/90 md:text-[0.75rem]"
					>
						Lore context
					</h2>
					<p class="mt-6 max-w-prose whitespace-pre-wrap break-words text-[1rem] leading-[1.85] text-neutral-400/82 md:text-[1.0625rem]">
						{loreContextText}
					</p>
				</section>
			)
		}

		{
			showCharacterLink && characterLinkText && (
				<section
					class="mt-[3.25rem] border-t border-neutral-800/32 pt-10 md:mt-[3.5rem] md:pt-11"
					aria-labelledby="character-link-heading"
				>
					<h2
						id="character-link-heading"
						class="border-b border-neutral-800/30 pb-4 text-[0.7rem] font-bold uppercase tracking-[0.14em] text-neutral-400/90 md:text-[0.75rem]"
					>
						Character link
					</h2>
					<p class="mt-6 max-w-prose whitespace-pre-wrap break-words text-[1rem] leading-[1.85] text-neutral-400/82 md:text-[1.0625rem]">
						{characterLinkText}
					</p>
				</section>
			)
		}

		{
			showPlaceOfOrigin && placeOfOriginText && (
				<section
					class="mt-[3.25rem] border-t border-neutral-800/32 pt-10 md:mt-[3.5rem] md:pt-11"
					aria-labelledby="place-of-origin-heading"
				>
					<h2
						id="place-of-origin-heading"
						class="border-b border-neutral-800/30 pb-4 text-[0.7rem] font-bold uppercase tracking-[0.14em] text-neutral-400/90 md:text-[0.75rem]"
					>
						Place of origin
					</h2>
					<p class="mt-6 max-w-prose whitespace-pre-wrap break-words text-[1rem] leading-[1.85] text-neutral-400/82 md:text-[1.0625rem]">
						{placeOfOriginText}
					</p>
				</section>
			)
		}

		{
			showSigilRelationships && (
				<section
					class="mt-[3.25rem] border-t border-neutral-800/32 pt-10 md:mt-[3.5rem] md:pt-11"
					aria-labelledby="sigil-relationships-heading"
				>
					<h2
						id="sigil-relationships-heading"
						class="border-b border-neutral-800/30 pb-4 text-[0.7rem] font-bold uppercase tracking-[0.14em] text-neutral-400/90 md:text-[0.75rem]"
					>
						Sigil relationships
					</h2>
					<p class="mt-4 max-w-prose text-[0.75rem] leading-relaxed text-neutral-500/85">
						Declared labels only — editorial strings, not automatic links or graph edges.
					</p>
					<ul class="mt-6 list-none space-y-3 text-[1rem] leading-[1.75] text-neutral-400/88 md:text-[1.0625rem]">
						{relationshipLines.map((line) => (
							<li class="border-l border-neutral-800/55 pl-4 whitespace-pre-wrap break-words">{line}</li>
						))}
					</ul>
				</section>
			)
		}

		{
			showPrototypeLoreSection && loreFromUnderlay && (
				<section
					class="mt-[3.25rem] border-t border-neutral-800/32 pt-10 md:mt-[3.5rem] md:pt-11"
					aria-labelledby="lore-heading"
				>
					<h2
						id="lore-heading"
						class="border-b border-neutral-800/30 pb-4 text-[0.7rem] font-bold uppercase tracking-[0.14em] text-neutral-400/90 md:text-[0.75rem]"
					>
						Lore (underlay)
					</h2>
					<p class="mt-6 max-w-prose whitespace-pre-wrap break-words text-[1rem] leading-[1.85] text-neutral-400/82 md:text-[1.0625rem]">
						{loreFromUnderlay}
					</p>
				</section>
			)
		}

		{
			showFunctionStrip && usage && (
				<section
					class="mt-[3.25rem] border-t border-neutral-800/32 pt-10 md:mt-[3.5rem] md:pt-11"
					aria-labelledby="function-heading"
				>
					<h2
						id="function-heading"
						class="border-b border-neutral-800/30 pb-5 text-[0.7rem] font-bold uppercase tracking-[0.14em] text-neutral-400/92 md:text-[0.75rem]"
					>
						Function within Empyrria
					</h2>
					<p class="mt-6 whitespace-pre-wrap break-words text-sm leading-[1.75] text-neutral-300/82 md:text-[0.9375rem]">
						{usage}
					</p>
				</section>
			)
		}

		{
			showClassification && (
				<section
					class="mt-[3.75rem] border-t border-neutral-800/32 pt-10 md:mt-[4.25rem] md:pt-11"
					aria-labelledby="classification-heading"
				>
					<h2
						id="classification-heading"
						class="border-b border-neutral-800/28 pb-4 text-[0.7rem] font-semibold uppercase tracking-[0.16em] text-neutral-400/88 md:text-[0.72rem]"
					>
						Classification
					</h2>
					<dl class="mt-7 space-y-7">
						{
							classificationGeometry && (
								<div>
									<dt class="text-[0.62rem] font-medium uppercase tracking-[0.2em] text-neutral-500/78">
										Geometry
									</dt>
									<dd class="mt-2.5 whitespace-pre-wrap break-words text-sm leading-[1.72] text-neutral-300/86">
										{classificationGeometry}
									</dd>
								</div>
							)
						}
						{
							category && (
								<div>
									<dt class="text-[0.62rem] font-medium uppercase tracking-[0.2em] text-neutral-500/78">
										Category
									</dt>
									<dd class="mt-2.5 whitespace-pre-wrap break-words text-sm leading-[1.72] text-neutral-300/86">
										{category}
									</dd>
								</div>
							)
						}
					</dl>
				</section>
			)
		}

		{
			showRelationsPreview && relationsPreview && (
				<section class="mt-9 md:mt-10" aria-label="Relations preview">
					<details class="group border-l border-neutral-800/55 pl-4">
						<summary class="cursor-pointer text-[0.62rem] font-medium uppercase tracking-[0.18em] text-neutral-500/78 transition-colors hover:text-neutral-400/88">
							Relations preview
						</summary>
						<p class="mt-3 max-w-prose whitespace-pre-wrap break-words text-sm leading-[1.72] text-neutral-400/76 md:text-[0.9375rem]">
							{relationsPreview}
						</p>
					</details>
				</section>
			)
		}

		{
			showLegacyUnderlay && (
				<section
					class="mt-24 border-t border-neutral-800/45 pt-14 md:mt-28 md:pt-16"
					aria-labelledby="underlay-heading"
				>
					<div class="rounded-lg border border-neutral-800/70 border-l-cyan-950/80 bg-neutral-900/25 px-5 py-8 md:px-6 md:py-9">
						<div class="space-y-4 border-b border-neutral-800/40 pb-8">
							<h2
								id="underlay-heading"
								class="text-lg font-bold uppercase tracking-[0.14em] text-cyan-300/82 md:text-xl"
							>
								Underlay
							</h2>
							<p class="text-sm font-bold uppercase tracking-[0.12em] text-neutral-400">
								System context
							</p>
						</div>
						<div class="mt-9 space-y-7 pt-2">
							{underlayText
								.split('\n')
								.filter((line) => line.trim().length > 0)
								.map((line) => {
									const parsed = parseUnderlayLine(line);
									return parsed.kind === 'pair' ? (
										<p class="text-[1.0625rem] leading-[2.15]">
											<span class="inline text-base font-bold text-cyan-400/72">{parsed.label}</span>
											<span class="inline whitespace-pre-wrap break-words pl-1.5 text-[1.0625rem] font-normal leading-[2.15] text-cyan-200/52">
												{parsed.value}
											</span>
										</p>
									) : (
										<p class="whitespace-pre-wrap break-words text-[1.0625rem] leading-[2.15] text-cyan-200/55">
											{parsed.text}
										</p>
									);
								})}
						</div>
					</div>
				</section>
			)
		}

		<p class="mt-20 border-t border-neutral-800/60 pt-10">
			<a
				href="/sigils"
				class="text-sm text-neutral-400 underline-offset-4 transition-colors hover:text-cyan-400/80 hover:underline"
			>
				← All sigils
			</a>
		</p>
	</main>
</Layout>
